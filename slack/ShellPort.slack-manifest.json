{
  "display_information": {
    "name": "ShellPort",
    "description": "Posts which interview question each candidate was assigned, and on which station.",
    "background_color": "#001413"
  },
  "features": {
    "bot_user": {
      "display_name": "ShellPort",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "chat:write.public"
      ]
    }
  },
  "settings": {
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
