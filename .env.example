# ShellPort Configuration
# The installer merges both: .env.defaults first, then secrets from SHELLPORT_ env vars.

# NON-SECRETS
ENABLE_TIMER="false"
TIMEOUT_ACTION="NOTIFY"
TIME_LIMIT_MINUTES="300"
INACTIVITY_TIMEOUT_MINUTES="10"
ENABLE_TELEMETRY="false"

# Comma-separated allow-list of local editors a candidate may launch.
# Empty = every detected editor is offered. Admins can also toggle these
# live in the dashboard (Admin → Settings → Editors).
ENABLED_EDITORS=""
# Allow "Start in terminal" (opens the native OS terminal in the container shell).
TERMINAL_ACCESS="true"

# How the assigned question is presented to the candidate. Admins can also change
# this live in the dashboard (Admin → Settings → Question → Delivery).
#   auto   - render inline; fall back to the PDF if it doesn't format cleanly
#   inline - always render inline
#   pdf    - always offer the PDF
#   none   - show nothing (question delivered separately, e.g. attached to the email)
QUESTION_DELIVERY="auto"

# Appearance (theme/accent/font) is NOT set here. Defaults are theme=system,
# accent=cerulean, font=sans; an admin changes them in the dashboard and the
# choice is saved to .appearance.json and inherited by the candidate view.
# Admin unlock uses the machine's OS-user password — there is no admin
# password to configure.

# SECRETS (injected at install time)
# QUESTION_WEBHOOK=""
# QUESTIONS_URL can be either:
#   - a Google Sheet (index of [title, docId] rows; QUESTION_ROW pins the row), or
#   - a Google Doc that holds one question per tab. Paste the doc link with the
#     desired tab selected (it carries ?tab=t.xxxx), or set QUESTION_TAB below.
# QUESTIONS_URL=""
# QUESTION_ROW=""        # Sheet mode: 1-based row of the assigned question (row 2 = first question)
# QUESTION_TAB=""        # Doc mode: tab id (e.g. t.abc123) of the assigned question
# PROJECT_NAME=""
# MACHINE_LABEL=""
